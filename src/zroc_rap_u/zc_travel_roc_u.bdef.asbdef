projection;
strict ( 2 );

define behavior for ZC_TRAVEL_ROC_U //alias <alias_name>
use etag    //read data from trasaction buffer, trigger read method
{
  use create;
  use update;
  use delete;

  use association _Booking { create; }
}

define behavior for ZC_BOOKING_ROC_U //alias <alias_name>
use etag  //该Etag interface behavior 定义为'etag dependent by _Travel', trigger rba_Travel method
{
  use update;
  use delete;

  use association _Travel;
}